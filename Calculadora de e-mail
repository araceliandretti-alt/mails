<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Score de Engajamento de E-mail</title>
<link href="https://fonts.googleapis.com/css2?family=Chivo:wght@400;500;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --orange: #FF6D01;
    --orange-dim: #CC5700;
    --bg: #0D0D0D;
    --bg2: #141414;
    --bg3: #1C1C1C;
    --bg4: #242424;
    --border: rgba(255,255,255,0.08);
    --border-orange: rgba(255,109,1,0.35);
    --text: #F5F0E8;
    --text-muted: rgba(245,240,232,0.5);
    --text-dim: rgba(245,240,232,0.25);
    --green: #4CAF50;
    --red: #E53935;
    --font-head: 'Chivo', sans-serif;
    --font-body: 'Inter', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  /* ── HEADER STRIP ── */
  .strip {
    background: var(--orange);
    overflow: hidden;
    padding: 8px 0;
    white-space: nowrap;
  }
  .strip-inner {
    display: inline-flex;
    gap: 48px;
    animation: marquee 18s linear infinite;
  }
  .strip-item {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .strip-item::before { content: '●'; font-size: 7px; opacity: .7; }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── HERO ── */
  .hero {
    text-align: center;
    padding: 20px 24px 18px;
    position: relative;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,109,1,.12);
    border: 1px solid var(--border-orange);
    border-radius: 2px;
    padding: 4px 12px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 10px;
  }
  .hero-eyebrow span { width: 5px; height: 5px; background: var(--orange); border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
  .hero h1 {
    font-family: var(--font-head);
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -.02em;
    margin-bottom: 6px;
  }
  .hero h1 em {
    font-style: normal;
    color: var(--orange);
  }
  .hero p {
    font-size: 13px;
    color: var(--text-muted);
    max-width: 380px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* ── LAYOUT ── */
  .wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px 64px;
  }

  /* ── SECTION LABEL ── */
  .sec-label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .sec-label-line {
    height: 1px;
    flex: 1;
    background: var(--border);
  }
  .sec-label-text {
    font-family: var(--font-head);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  /* ── CARDS ── */
  .grid2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 12px;
  }
  @media (max-width: 600px) { .grid2 { grid-template-columns: 1fr; } }

  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color .2s;
  }
  .card:hover { border-color: rgba(255,109,1,.25); }
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
  }
  .card.card-ref::before  { background: rgba(255,255,255,.12); }
  .card.card-camp::before { background: var(--orange); }

  .card-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }
  .card-icon {
    width: 34px; height: 34px;
    border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px;
    flex-shrink: 0;
  }
  .ci-ref  { background: var(--bg4); color: var(--text-muted); }
  .ci-camp { background: rgba(255,109,1,.15); color: var(--orange); }
  .card-title {
    font-family: var(--font-head);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .02em;
    color: var(--text);
  }
  .card-sub { font-size: 11px; color: var(--text-dim); margin-top: 1px; }

  /* ── SLIDERS ── */
  .sl-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .sl-row:last-child { margin-bottom: 0; }
  .sl-label {
    font-size: 12px;
    color: var(--text-muted);
    width: 108px;
    flex-shrink: 0;
    line-height: 1.3;
  }
  input[type=range] {
    flex: 1;
    appearance: none;
    height: 3px;
    background: var(--bg4);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }
  input[type=range]::-webkit-slider-thumb {
    appearance: none;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: var(--orange);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 1px var(--orange);
    transition: transform .15s;
  }
  input[type=range]::-webkit-slider-thumb:hover { transform: scale(1.2); }
  .sl-val {
    font-family: var(--font-head);
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    min-width: 42px;
    text-align: right;
  }
  .sl-status {
    font-size: 10px;
    font-weight: 600;
    padding: 1px 5px;
    border-radius: 2px;
    margin-left: 4px;
    vertical-align: middle;
  }
  .st-up   { background: rgba(76,175,80,.15); color: #81C784; }
  .st-dn   { background: rgba(229,57,53,.15); color: #EF9A9A; }
  .st-eq   { background: var(--bg4); color: var(--text-dim); }

  /* ── DIVIDER ── */
  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 28px 0;
  }
  .divider-orange {
    border: none;
    border-top: 1px solid var(--border-orange);
    margin: 28px 0;
  }

  /* ── COMPONENT CARDS ── */
  .comp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 12px;
  }
  @media (max-width: 560px) { .comp-grid { grid-template-columns: 1fr; } }

  .comp-card {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 16px;
    transition: border-color .2s;
  }
  .comp-card:hover { border-color: rgba(255,109,1,.2); }
  .comp-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .comp-tag {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 2px;
  }
  .ct-blue   { background: rgba(55,138,221,.15); color: #64B5F6; border: 1px solid rgba(55,138,221,.2); }
  .ct-orange { background: rgba(255,109,1,.12);  color: var(--orange); border: 1px solid var(--border-orange); }
  .comp-weight { font-size: 11px; color: var(--text-dim); }
  .comp-formula {
    font-family: 'Courier New', monospace;
    font-size: 10.5px;
    color: var(--text-dim);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 5px 9px;
    margin-bottom: 10px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .comp-bar-wrap {
    height: 4px;
    background: var(--bg);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 10px;
  }
  .comp-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width .5s cubic-bezier(.4,0,.2,1);
  }
  .fill-blue   { background: #378ADD; }
  .fill-orange { background: var(--orange); }
  .comp-nums {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .comp-score {
    font-family: var(--font-head);
    font-size: 22px;
    font-weight: 900;
  }
  .cs-blue   { color: #64B5F6; }
  .cs-orange { color: var(--orange); }
  .comp-result { font-size: 11px; color: var(--text-dim); }

  /* ── FINAL CARD ── */
  .final-card {
    background: var(--bg2);
    border: 1px solid var(--border-orange);
    border-radius: 4px;
    padding: 32px 24px 28px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .final-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--orange);
  }
  .final-glow {
    position: absolute;
    top: -60px; left: 50%;
    transform: translateX(-50%);
    width: 200px; height: 120px;
    background: radial-gradient(ellipse, rgba(255,109,1,.18) 0%, transparent 70%);
    pointer-events: none;
  }
  .final-formula {
    font-family: 'Courier New', monospace;
    font-size: 12px;
    color: var(--text-dim);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 7px 14px;
    display: inline-block;
    margin-bottom: 20px;
  }
  .final-score {
    font-family: var(--font-head);
    font-size: 72px;
    font-weight: 900;
    line-height: 1;
    color: var(--text);
    letter-spacing: -.04em;
    margin-bottom: 14px;
    transition: color .4s;
  }
  .final-badge {
    display: inline-block;
    padding: 7px 24px;
    border-radius: 2px;
    font-family: var(--font-head);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 14px;
    border: 1px solid currentColor;
  }
  .final-interp {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 400px;
    margin: 0 auto;
  }

  /* badge colors */
  .badge-ex  { color: #81C784; background: rgba(76,175,80,.1); }
  .badge-bom { color: #64B5F6; background: rgba(55,138,221,.1); }
  .badge-reg { color: var(--orange); background: rgba(255,109,1,.1); }
  .badge-rui { color: #EF9A9A; background: rgba(229,57,53,.1); }

  /* ── LEGEND ── */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--text-dim);
  }
  .legend-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── FOOTER ── */
  .footer {
    text-align: center;
    padding: 20px;
    font-size: 11px;
    color: var(--text-dim);
    border-top: 1px solid var(--border);
    letter-spacing: .04em;
  }
</style>
</head>
<body>



<!-- HERO -->
<div class="hero">
  <div class="hero-eyebrow"><span></span>Email Marketing</div>
  <h1>Score de<br><em>Engajamento</em></h1>
  <p>Ajuste os valores e veja o score calculado em tempo real</p>
</div>

<!-- MAIN -->
<div class="wrap">

  <!-- INPUTS -->
  <div class="sec-label">
    <div class="sec-label-line"></div>
    <span class="sec-label-text">Parâmetros</span>
    <div class="sec-label-line"></div>
  </div>

  <div class="grid2">
    <!-- Médias -->
    <div class="card card-ref">
      <div class="card-head">
        <div class="card-icon ci-ref">📊</div>
        <div>
          <div class="card-title">Médias de referência</div>
          <div class="card-sub">Benchmark histórico</div>
        </div>
      </div>
      <div class="sl-row">
        <span class="sl-label">% abertura média</span>
        <input type="range" min="5" max="50" step="1" value="25" id="m_aber">
        <span class="sl-val" id="m_aber_v">25%</span>
      </div>
      <div class="sl-row">
        <span class="sl-label">Vol. aberturas médio</span>
        <input type="range" min="100" max="2000" step="50" value="500" id="m_vol_aber">
        <span class="sl-val" id="m_vol_aber_v">500</span>
      </div>
      <div class="sl-row">
        <span class="sl-label">% CTOR média</span>
        <input type="range" min="2" max="40" step="1" value="15" id="m_ctor">
        <span class="sl-val" id="m_ctor_v">15%</span>
      </div>
      <div class="sl-row">
        <span class="sl-label">Cliques únicos médios</span>
        <input type="range" min="20" max="1000" step="10" value="100" id="m_cliq">
        <span class="sl-val" id="m_cliq_v">100</span>
      </div>
    </div>

    <!-- Campanha -->
    <div class="card card-camp">
      <div class="card-head">
        <div class="card-icon ci-camp">✉️</div>
        <div>
          <div class="card-title">Valores da campanha</div>
          <div class="card-sub">Resultados desta campanha</div>
        </div>
      </div>
      <div class="sl-row">
        <span class="sl-label">% abertura <span class="sl-status" id="s_aber"></span></span>
        <input type="range" min="5" max="50" step="1" value="20" id="c_aber">
        <span class="sl-val" id="c_aber_v">20%</span>
      </div>
      <div class="sl-row">
        <span class="sl-label">Vol. aberturas <span class="sl-status" id="s_vol_aber"></span></span>
        <input type="range" min="100" max="2000" step="50" value="800" id="c_vol_aber">
        <span class="sl-val" id="c_vol_aber_v">800</span>
      </div>
      <div class="sl-row">
        <span class="sl-label">% CTOR <span class="sl-status" id="s_ctor"></span></span>
        <input type="range" min="2" max="40" step="1" value="18" id="c_ctor">
        <span class="sl-val" id="c_ctor_v">18%</span>
      </div>
      <div class="sl-row">
        <span class="sl-label">Cliques únicos <span class="sl-status" id="s_cliq"></span></span>
        <input type="range" min="20" max="1000" step="10" value="160" id="c_cliq">
        <span class="sl-val" id="c_cliq_v">160</span>
      </div>
    </div>
  </div>

  <hr class="divider">

  <!-- RESULTADO FINAL -->
  <div class="sec-label">
    <div class="sec-label-line"></div>
    <span class="sec-label-text">Resultado</span>
    <div class="sec-label-line"></div>
  </div>

  <div class="final-card">
    <div class="final-glow"></div>
    <div class="final-formula" id="soma_desc">–</div>
    <div class="final-score" id="score_final">–</div>
    <div><span class="final-badge" id="badge_class">–</span></div>
    <p class="final-interp" id="interpretacao">–</p>
  </div>

  <hr class="divider">

  <!-- COMPONENTES -->
  <div class="sec-label">
    <div class="sec-label-line"></div>
    <span class="sec-label-text">Composição do score</span>
    <div class="sec-label-line"></div>
  </div>

  <div class="comp-grid">
    <div class="comp-card">
      <div class="comp-top">
        <span class="comp-tag ct-blue">% Abertura</span>
        <span class="comp-weight">peso 16%</span>
      </div>
      <div class="comp-formula" id="f_aber">–</div>
      <div class="comp-bar-wrap"><div class="comp-bar-fill fill-blue" id="b_aber" style="width:0%"></div></div>
      <div class="comp-nums">
        <span class="comp-score cs-blue" id="sc_aber">–</span>
        <span class="comp-result" id="pr_aber">–</span>
      </div>
    </div>

    <div class="comp-card">
      <div class="comp-top">
        <span class="comp-tag ct-blue">Vol. Aberturas</span>
        <span class="comp-weight">peso 24%</span>
      </div>
      <div class="comp-formula" id="f_vol_aber">–</div>
      <div class="comp-bar-wrap"><div class="comp-bar-fill fill-blue" id="b_vol_aber" style="width:0%"></div></div>
      <div class="comp-nums">
        <span class="comp-score cs-blue" id="sc_vol_aber">–</span>
        <span class="comp-result" id="pr_vol_aber">–</span>
      </div>
    </div>

    <div class="comp-card">
      <div class="comp-top">
        <span class="comp-tag ct-orange">% CTOR</span>
        <span class="comp-weight">peso 24%</span>
      </div>
      <div class="comp-formula" id="f_ctor">–</div>
      <div class="comp-bar-wrap"><div class="comp-bar-fill fill-orange" id="b_ctor" style="width:0%"></div></div>
      <div class="comp-nums">
        <span class="comp-score cs-orange" id="sc_ctor">–</span>
        <span class="comp-result" id="pr_ctor">–</span>
      </div>
    </div>

    <div class="comp-card">
      <div class="comp-top">
        <span class="comp-tag ct-orange">Cliques únicos</span>
        <span class="comp-weight">peso 36%</span>
      </div>
      <div class="comp-formula" id="f_cliq">–</div>
      <div class="comp-bar-wrap"><div class="comp-bar-fill fill-orange" id="b_cliq" style="width:0%"></div></div>
      <div class="comp-nums">
        <span class="comp-score cs-orange" id="sc_cliq">–</span>
        <span class="comp-result" id="pr_cliq">–</span>
      </div>
    </div>
  </div>

  <!-- LEGEND -->
  <div class="legend">
    <div class="legend-item"><div class="legend-dot" style="background:#64B5F6"></div>Abertura (taxa + volume)</div>
    <div class="legend-item"><div class="legend-dot" style="background:#FF6D01"></div>Cliques (CTOR + únicos)</div>
    <div class="legend-item"><div class="legend-dot" style="background:#81C784"></div>Excelente ≥ 0.80</div>
    <div class="legend-item"><div class="legend-dot" style="background:#64B5F6"></div>Bom ≥ 0.60</div>
    <div class="legend-item"><div class="legend-dot" style="background:#FF6D01"></div>Regular ≥ 0.40</div>
    <div class="legend-item"><div class="legend-dot" style="background:#EF9A9A"></div>Ruim &lt; 0.40</div>
  </div>

</div>

<div class="footer">Score de Engajamento de E-mail · Calculadora Interativa</div>

<script>
function status(val, media) {
  if (val > media) return '<span class="sl-status st-up">↑ acima</span>';
  if (val < media) return '<span class="sl-status st-dn">↓ abaixo</span>';
  return '<span class="sl-status st-eq">= média</span>';
}
function classificar(s) {
  if (s >= 0.80) return { texto:'Excelente', cls:'badge-ex',  scoreColor:'#81C784' };
  if (s >= 0.60) return { texto:'Bom',       cls:'badge-bom', scoreColor:'#64B5F6' };
  if (s >= 0.40) return { texto:'Regular',   cls:'badge-reg', scoreColor:'#FF6D01' };
  return              { texto:'Ruim',       cls:'badge-rui', scoreColor:'#EF9A9A' };
}
function interpretar(aber, vol_aber, ctor, cliq, ma, mva, mc, mcliq) {
  let p = [];
  p.push(aber < ma ? 'taxa de abertura abaixo da média' : 'taxa de abertura boa');
  if (vol_aber > mva) p.push('volume de aberturas expressivo');
  p.push(ctor >= mc ? 'CTOR acima da média' : 'CTOR abaixo da média');
  if (cliq > mcliq) p.push('cliques acima da média');
  return p.join(', ') + '.';
}
function g(id) { return document.getElementById(id); }

function calc() {
  const ma=+g('m_aber').value, mva=+g('m_vol_aber').value, mc=+g('m_ctor').value, mcliq=+g('m_cliq').value;
  const ca=+g('c_aber').value, cva=+g('c_vol_aber').value, cc=+g('c_ctor').value, ccliq=+g('c_cliq').value;

  g('m_aber_v').textContent=ma+'%'; g('m_vol_aber_v').textContent=mva;
  g('m_ctor_v').textContent=mc+'%'; g('m_cliq_v').textContent=mcliq;
  g('c_aber_v').textContent=ca+'%'; g('c_vol_aber_v').textContent=cva;
  g('c_ctor_v').textContent=cc+'%'; g('c_cliq_v').textContent=ccliq;

  g('s_aber').innerHTML=status(ca,ma); g('s_vol_aber').innerHTML=status(cva,mva);
  g('s_ctor').innerHTML=status(cc,mc); g('s_cliq').innerHTML=status(ccliq,mcliq);

  const sc_aber=Math.min(1,ca/Math.max(ca,ma));
  const sc_vol_aber=cva/(cva+mva);
  const sc_ctor=Math.min(1,cc/Math.max(cc,mc));
  const sc_cliq=ccliq/(ccliq+mcliq);

  const p_aber=sc_aber*0.16, p_vol_aber=sc_vol_aber*0.24, p_ctor=sc_ctor*0.24, p_cliq=sc_cliq*0.36;
  const total=Math.min(1,p_aber+p_vol_aber+p_ctor+p_cliq);

  const da=Math.max(ca,ma), dc=Math.max(cc,mc);
  g('f_aber').textContent=ca+' / máx('+ca+';'+ma+') = '+da+' → '+sc_aber.toFixed(2);
  g('f_vol_aber').textContent=cva+' / ('+cva+'+'+mva+') = '+(cva+mva)+' → '+sc_vol_aber.toFixed(2);
  g('f_ctor').textContent=cc+' / máx('+cc+';'+mc+') = '+dc+' → '+sc_ctor.toFixed(2);
  g('f_cliq').textContent=ccliq+' / ('+ccliq+'+'+mcliq+') = '+(ccliq+mcliq)+' → '+sc_cliq.toFixed(2);

  g('b_aber').style.width=(sc_aber*100).toFixed(1)+'%';
  g('b_vol_aber').style.width=(sc_vol_aber*100).toFixed(1)+'%';
  g('b_ctor').style.width=(sc_ctor*100).toFixed(1)+'%';
  g('b_cliq').style.width=(sc_cliq*100).toFixed(1)+'%';

  g('sc_aber').textContent=sc_aber.toFixed(2); g('sc_vol_aber').textContent=sc_vol_aber.toFixed(2);
  g('sc_ctor').textContent=sc_ctor.toFixed(2); g('sc_cliq').textContent=sc_cliq.toFixed(2);

  g('pr_aber').textContent='× 16% = '+p_aber.toFixed(3);
  g('pr_vol_aber').textContent='× 24% = '+p_vol_aber.toFixed(3);
  g('pr_ctor').textContent='× 24% = '+p_ctor.toFixed(3);
  g('pr_cliq').textContent='× 36% = '+p_cliq.toFixed(3);

  g('soma_desc').textContent=p_aber.toFixed(3)+' + '+p_vol_aber.toFixed(3)+' + '+p_ctor.toFixed(3)+' + '+p_cliq.toFixed(3)+' = '+total.toFixed(3);
  g('score_final').textContent=total.toFixed(3);

  const cls=classificar(total);
  g('score_final').style.color=cls.scoreColor;
  const badge=g('badge_class');
  badge.textContent=cls.texto;
  badge.className='final-badge '+cls.cls;
  g('interpretacao').textContent=interpretar(ca,cva,cc,ccliq,ma,mva,mc,mcliq);
}

document.querySelectorAll('input[type=range]').forEach(el=>el.addEventListener('input',calc));
calc();
</script>
</body>
</html>
