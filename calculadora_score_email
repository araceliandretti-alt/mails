

<style>
  .bloco { background: var(--color-background-secondary); border-radius: var(--border-radius-lg); padding: 1rem 1.25rem; margin-bottom: 10px; }
  .label { font-size: 12px; color: var(--color-text-secondary); margin: 0 0 6px; }
  .row { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
  .formula { font-family: var(--font-mono); font-size: 13px; color: var(--color-text-secondary); background: var(--color-background-tertiary); padding: 5px 10px; border-radius: 6px; flex: 1; }
  .bar-wrap { height: 8px; background: var(--color-background-tertiary); border-radius: 4px; flex: 1; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 4px; transition: width 0.3s; }
  .score-comp { font-size: 15px; font-weight: 500; min-width: 38px; text-align: right; }
  .peso-result { font-size: 13px; color: var(--color-text-secondary); min-width: 90px; }
  .section-title { font-size: 13px; font-weight: 500; color: var(--color-text-primary); margin: 0 0 8px; }
  .tag { font-size: 11px; padding: 2px 8px; border-radius: 5px; }
  .tag-blue  { background:#E6F1FB; color:#0C447C; }
  .tag-amber { background:#FAEEDA; color:#633806; }
  .final-card { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 1.25rem; text-align: center; margin-top: 1rem; }
  .badge { display: inline-block; padding: 4px 16px; border-radius: 20px; font-size: 13px; font-weight: 500; }
  .slider-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .slider-label { font-size: 13px; color: var(--color-text-secondary); min-width: 140px; }
  .slider-val { font-size: 14px; font-weight: 500; min-width: 36px; text-align: right; color: var(--color-text-primary); }
  .divider { border: none; border-top: 0.5px solid var(--color-border-tertiary); margin: 1rem 0; }
  .status { font-size: 12px; margin-left: 6px; }
  .up { color: #0F6E56; }
  .down { color: #A32D2D; }
  .eq { color: var(--color-text-secondary); }
</style>

<h2 class="sr-only">Calculadora interativa do score de engajamento de e-mail</h2>

<p class="section-title">Médias de referência</p>
<div class="bloco">
  <div class="slider-row">
    <span class="slider-label">% abertura média</span>
    <input type="range" min="5" max="50" step="1" value="25" id="m_aber" style="flex:1">
    <span class="slider-val" id="m_aber_v">25%</span>
  </div>
  <div class="slider-row">
    <span class="slider-label">Volume aberturas médio</span>
    <input type="range" min="100" max="2000" step="50" value="500" id="m_vol_aber" style="flex:1">
    <span class="slider-val" id="m_vol_aber_v">500</span>
  </div>
  <div class="slider-row">
    <span class="slider-label">% CTOR média</span>
    <input type="range" min="2" max="40" step="1" value="15" id="m_ctor" style="flex:1">
    <span class="slider-val" id="m_ctor_v">15%</span>
  </div>
  <div class="slider-row" style="margin-bottom:0">
    <span class="slider-label">Cliques únicos médios</span>
    <input type="range" min="20" max="1000" step="10" value="100" id="m_cliq" style="flex:1">
    <span class="slider-val" id="m_cliq_v">100</span>
  </div>
</div>

<p class="section-title">Valores da campanha</p>
<div class="bloco">
  <div class="slider-row">
    <span class="slider-label">% abertura <span class="status" id="s_aber"></span></span>
    <input type="range" min="5" max="50" step="1" value="20" id="c_aber" style="flex:1">
    <span class="slider-val" id="c_aber_v">20%</span>
  </div>
  <div class="slider-row">
    <span class="slider-label">Volume aberturas <span class="status" id="s_vol_aber"></span></span>
    <input type="range" min="100" max="2000" step="50" value="800" id="c_vol_aber" style="flex:1">
    <span class="slider-val" id="c_vol_aber_v">800</span>
  </div>
  <div class="slider-row">
    <span class="slider-label">% CTOR <span class="status" id="s_ctor"></span></span>
    <input type="range" min="2" max="40" step="1" value="18" id="c_ctor" style="flex:1">
    <span class="slider-val" id="c_ctor_v">18%</span>
  </div>
  <div class="slider-row" style="margin-bottom:0">
    <span class="slider-label">Cliques únicos <span class="status" id="s_cliq"></span></span>
    <input type="range" min="20" max="1000" step="10" value="160" id="c_cliq" style="flex:1">
    <span class="slider-val" id="c_cliq_v">160</span>
  </div>
</div>

<hr class="divider">

<p class="section-title">Como ficou cada componente</p>

<div class="bloco">
  <div class="row" style="margin-bottom:4px">
    <span class="tag tag-blue">% abertura</span>
    <span style="font-size:12px;color:var(--color-text-secondary)">peso 16% · taxa (teto em 1)</span>
  </div>
  <div class="row">
    <span class="formula" id="f_aber">–</span>
  </div>
  <div class="row">
    <span class="bar-wrap"><span class="bar-fill" id="b_aber" style="background:#378ADD;width:0%"></span></span>
    <span class="score-comp" id="sc_aber" style="color:#185FA5">–</span>
    <span class="peso-result" id="pr_aber">–</span>
  </div>
</div>

<div class="bloco">
  <div class="row" style="margin-bottom:4px">
    <span class="tag tag-blue">Volume aberturas</span>
    <span style="font-size:12px;color:var(--color-text-secondary)">peso 24% · volume (curva suavizada)</span>
  </div>
  <div class="row">
    <span class="formula" id="f_vol_aber">–</span>
  </div>
  <div class="row">
    <span class="bar-wrap"><span class="bar-fill" id="b_vol_aber" style="background:#378ADD;width:0%"></span></span>
    <span class="score-comp" id="sc_vol_aber" style="color:#185FA5">–</span>
    <span class="peso-result" id="pr_vol_aber">–</span>
  </div>
</div>

<div class="bloco">
  <div class="row" style="margin-bottom:4px">
    <span class="tag tag-amber">% CTOR</span>
    <span style="font-size:12px;color:var(--color-text-secondary)">peso 24% · taxa (teto em 1)</span>
  </div>
  <div class="row">
    <span class="formula" id="f_ctor">–</span>
  </div>
  <div class="row">
    <span class="bar-wrap"><span class="bar-fill" id="b_ctor" style="background:#BA7517;width:0%"></span></span>
    <span class="score-comp" id="sc_ctor" style="color:#633806">–</span>
    <span class="peso-result" id="pr_ctor">–</span>
  </div>
</div>

<div class="bloco">
  <div class="row" style="margin-bottom:4px">
    <span class="tag tag-amber">Cliques únicos</span>
    <span style="font-size:12px;color:var(--color-text-secondary)">peso 36% · volume (curva suavizada)</span>
  </div>
  <div class="row">
    <span class="formula" id="f_cliq">–</span>
  </div>
  <div class="row">
    <span class="bar-wrap"><span class="bar-fill" id="b_cliq" style="background:#BA7517;width:0%"></span></span>
    <span class="score-comp" id="sc_cliq" style="color:#633806">–</span>
    <span class="peso-result" id="pr_cliq">–</span>
  </div>
</div>

<div class="final-card">
  <p style="font-size:13px;color:var(--color-text-secondary);margin:0 0 4px" id="soma_desc">–</p>
  <p style="font-size:36px;font-weight:500;color:var(--color-text-primary);margin:0 0 10px" id="score_final">–</p>
  <span class="badge" id="badge_class">–</span>
  <p style="font-size:12px;color:var(--color-text-secondary);margin:10px 0 0" id="interpretacao">–</p>
</div>

<script>
function status(val, media) {
  if (val > media) return '<span class="up">↑ acima</span>';
  if (val < media) return '<span class="down">↓ abaixo</span>';
  return '<span class="eq">= na média</span>';
}

function classificar(s) {
  if (s >= 0.80) return { texto: 'Excelente', bg: '#EAF3DE', cor: '#27500A' };
  if (s >= 0.60) return { texto: 'Bom',       bg: '#E6F1FB', cor: '#0C447C' };
  if (s >= 0.40) return { texto: 'Regular',   bg: '#FAEEDA', cor: '#633806' };
  return              { texto: 'Ruim',       bg: '#FCEBEB', cor: '#791F1F' };
}

function interpretar(aber, vol_aber, ctor, cliq, ma, mva, mc, mcliq) {
  let pontos = [];
  if (aber < ma)       pontos.push('taxa de abertura abaixo da média');
  else                 pontos.push('taxa de abertura boa');
  if (vol_aber > mva)  pontos.push('volume de aberturas expressivo');
  if (ctor >= mc)      pontos.push('CTOR acima da média');
  else                 pontos.push('CTOR abaixo da média');
  if (cliq > mcliq)    pontos.push('cliques acima da média');
  return pontos.join(', ') + '.';
}

function calc() {
  const ma   = +document.getElementById('m_aber').value;
  const mva  = +document.getElementById('m_vol_aber').value;
  const mc   = +document.getElementById('m_ctor').value;
  const mcliq= +document.getElementById('m_cliq').value;
  const ca   = +document.getElementById('c_aber').value;
  const cva  = +document.getElementById('c_vol_aber').value;
  const cc   = +document.getElementById('c_ctor').value;
  const ccliq= +document.getElementById('c_cliq').value;

  document.getElementById('m_aber_v').textContent    = ma + '%';
  document.getElementById('m_vol_aber_v').textContent = mva;
  document.getElementById('m_ctor_v').textContent    = mc + '%';
  document.getElementById('m_cliq_v').textContent    = mcliq;
  document.getElementById('c_aber_v').textContent    = ca + '%';
  document.getElementById('c_vol_aber_v').textContent = cva;
  document.getElementById('c_ctor_v').textContent    = cc + '%';
  document.getElementById('c_cliq_v').textContent    = ccliq;

  document.getElementById('s_aber').innerHTML     = status(ca, ma);
  document.getElementById('s_vol_aber').innerHTML = status(cva, mva);
  document.getElementById('s_ctor').innerHTML     = status(cc, mc);
  document.getElementById('s_cliq').innerHTML     = status(ccliq, mcliq);

  const sc_aber     = Math.min(1, ca / Math.max(ca, ma));
  const sc_vol_aber = cva / (cva + mva);
  const sc_ctor     = Math.min(1, cc / Math.max(cc, mc));
  const sc_cliq     = ccliq / (ccliq + mcliq);

  const p_aber     = sc_aber     * 0.16;
  const p_vol_aber = sc_vol_aber * 0.24;
  const p_ctor     = sc_ctor     * 0.24;
  const p_cliq     = sc_cliq     * 0.36;

  const total = Math.min(1, p_aber + p_vol_aber + p_ctor + p_cliq);

  const denom_aber = Math.max(ca, ma);
  document.getElementById('f_aber').textContent     = ca + ' / máx(' + ca + '; ' + ma + ') = ' + ca + ' / ' + denom_aber + ' = ' + sc_aber.toFixed(2);
  document.getElementById('f_vol_aber').textContent = cva + ' / (' + cva + ' + ' + mva + ') = ' + cva + ' / ' + (cva+mva) + ' = ' + sc_vol_aber.toFixed(2);
  const denom_ctor = Math.max(cc, mc);
  document.getElementById('f_ctor').textContent     = cc + ' / máx(' + cc + '; ' + mc + ') = ' + cc + ' / ' + denom_ctor + ' = ' + sc_ctor.toFixed(2);
  document.getElementById('f_cliq').textContent     = ccliq + ' / (' + ccliq + ' + ' + mcliq + ') = ' + ccliq + ' / ' + (ccliq+mcliq) + ' = ' + sc_cliq.toFixed(2);

  document.getElementById('b_aber').style.width     = (sc_aber * 100).toFixed(1) + '%';
  document.getElementById('b_vol_aber').style.width = (sc_vol_aber * 100).toFixed(1) + '%';
  document.getElementById('b_ctor').style.width     = (sc_ctor * 100).toFixed(1) + '%';
  document.getElementById('b_cliq').style.width     = (sc_cliq * 100).toFixed(1) + '%';

  document.getElementById('sc_aber').textContent     = sc_aber.toFixed(2);
  document.getElementById('sc_vol_aber').textContent = sc_vol_aber.toFixed(2);
  document.getElementById('sc_ctor').textContent     = sc_ctor.toFixed(2);
  document.getElementById('sc_cliq').textContent     = sc_cliq.toFixed(2);

  document.getElementById('pr_aber').textContent     = '× 16% = ' + p_aber.toFixed(3);
  document.getElementById('pr_vol_aber').textContent = '× 24% = ' + p_vol_aber.toFixed(3);
  document.getElementById('pr_ctor').textContent     = '× 24% = ' + p_ctor.toFixed(3);
  document.getElementById('pr_cliq').textContent     = '× 36% = ' + p_cliq.toFixed(3);

  document.getElementById('soma_desc').textContent =
    p_aber.toFixed(3) + ' + ' + p_vol_aber.toFixed(3) + ' + ' + p_ctor.toFixed(3) + ' + ' + p_cliq.toFixed(3) + ' = ' + total.toFixed(3);

  document.getElementById('score_final').textContent = total.toFixed(3);

  const cls = classificar(total);
  const badge = document.getElementById('badge_class');
  badge.textContent = cls.texto;
  badge.style.background = cls.bg;
  badge.style.color = cls.cor;

  document.getElementById('interpretacao').textContent = interpretar(ca, cva, cc, ccliq, ma, mva, mc, mcliq);
}

document.querySelectorAll('input[type=range]').forEach(el => el.addEventListener('input', calc));
calc();
</script>
