            </span>
            <div className="h-px flex-1" style={{ background: "var(--border)" }} />
          </div>

          {/* Blocos da fase Isca */}
          <div className="space-y-3">
            {FUNIL_DATA.filter((n) => n.phase === "isca").map((node) => (
              <FunilBlock
                key={node.id}
                node={node}
