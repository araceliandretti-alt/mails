// ─── Utilitários de localStorage ────────────────────────────────────────────

const STORAGE_KEY = "funil-lipedema-notes";

function loadNotes(): Record<string, string> {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? JSON.parse(raw) : {};
  } catch {
    return {};
  }
}

function saveNotes(notes: Record<string, string>) {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(notes));
  } catch {
    // silently fail
  }
}

// ─── Componente de bloco expansível ─────────────────────────────────────────

interface FunilBlockProps {
  node: FunilNode;
  isOpen: boolean;
  onToggle: () => void;
  note: string;
  onNoteChange: (val: string) => void;
  savedIndicator: boolean;
  isActive: boolean;
  onActivate: () => void;
}

function FunilBlock({ node, isOpen, onToggle, note, onNoteChange, savedIndicator, isActive, onActivate }: FunilBlockProps) {
  const contentRef = useRef<HTMLDivElement>(null);
  const [height, setHeight] = useState<number | "auto">(0);

  useEffect(() => {
    if (!contentRef.current) return;
    if (isOpen) {
      const h = contentRef.current.scrollHeight;
      setHeight(h);
      const timer = setTimeout(() => setHeight("auto"), 210);
      return () => clearTimeout(timer);
    } else {
      setHeight(contentRef.current.scrollHeight);
      requestAnimationFrame(() => {
        requestAnimationFrame(() => setHeight(0));
      });
    }
  }, [isOpen]);

  const phaseClass = node.phase === "isca" ? "phase-isca" : "phase-trip";
  const badgeClass = node.phase === "isca" ? "isca" : "trip";
  const badgeLabel = node.phase === "isca" ? "ISCA" : "TRIP";

  return (
    <div
      id={`block-${node.id}`}
      className={`funil-block ${phaseClass} ${isActive ? "ring-1 ring-offset-0" : ""}`}
      style={isActive ? { outline: `2px solid ${node.phase === "isca" ? "var(--isca-color)" : "var(--trip-color)"}`, outlineOffset: "0px" } : {}}
      onClick={onActivate}
    >
      {/* Header do bloco */}
      <button
        className="w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-[var(--notion-hover)] transition-colors duration-100"
        onClick={(e) => { e.stopPropagation(); onToggle(); onActivate(); }}
      >
        <span className="text-[var(--notion-text-secondary)] flex-shrink-0">
          {isOpen ? <ChevronDown size={14} /> : <ChevronRight size={14} />}
        </span>
        <span
          className="flex-shrink-0 p-1.5 rounded"
          style={{
            background: node.phase === "isca" ? "oklch(0.93 0.06 258)" : "oklch(0.93 0.06 293)",
            color: node.phase === "isca" ? "oklch(0.42 0.18 258)" : "oklch(0.42 0.18 293)",
          }}
        >
          {node.icon}
        </span>
        <span className="flex-1 font-semibold text-[var(--notion-text)] text-sm" style={{ fontFamily: "'DM Sans', sans-serif" }}>
          {node.label}
        </span>
        <span className={`phase-badge ${badgeClass}`}>{badgeLabel}</span>
        {node.subItems.length > 0 && (
          <span className="text-[11px] text-[var(--notion-text-secondary)] font-mono ml-1">
            {node.subItems.length}
          </span>
        )}
      </button>

      {/* Conteúdo expansível */}
      <div
        className="accordion-content"
        style={{ height: height === "auto" ? "auto" : `${height}px` }}
      >
        <div ref={contentRef}>
          <div className="px-4 pb-4 pt-1 space-y-4">
            {/* Descrição e papel estratégico */}
            <div className="space-y-1.5">
              <p className="text-[13px] text-[var(--notion-text)]">{node.description}</p>
              <p className="text-[12px] text-[var(--notion-text-secondary)] italic">
                <span className="font-medium not-italic" style={{ fontFamily: "'JetBrains Mono', monospace", fontSize: "11px" }}>Papel estratégico:</span>{" "}
                {node.strategicRole}
              </p>
            </div>

            {/* Subtópicos */}
            {node.subItems.length > 0 && (
              <div className="space-y-1">
                <p className="text-[11px] font-semibold text-[var(--notion-text-secondary)] uppercase tracking-wider" style={{ fontFamily: "'JetBrains Mono', monospace" }}>
                  Subtópicos
                </p>
                <div className="space-y-1">
                  {node.subItems.map((item) => (
                    <SubItemRow key={item.id} item={item} phase={node.phase} />
                  ))}
                </div>
              </div>
            )}

            {/* Área de notas */}
            <div className="space-y-1.5">
              <div className="flex items-center justify-between">
                <p className="text-[11px] font-semibold text-[var(--notion-text-secondary)] uppercase tracking-wider" style={{ fontFamily: "'JetBrains Mono', monospace" }}>
                  Notas
                </p>
                <span className={`save-indicator ${savedIndicator ? "visible" : ""}`}>
                  ✓ salvo
                </span>
              </div>
              <div
                className="rounded p-2.5 min-h-[70px]"
                style={{ background: "oklch(0.975 0.003 60)" }}
              >
                <textarea
                  className="notion-textarea"
                  value={note}
                  onChange={(e) => onNoteChange(e.target.value)}
                  placeholder={node.notePlaceholder}
                  rows={3}
                  onClick={(e) => e.stopPropagation()}
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}

// ─── Sub-item expansível ─────────────────────────────────────────────────────

function SubItemRow({ item, phase }: { item: SubItem; phase: Phase }) {
  const [open, setOpen] = useState(false);
  const dotColor = phase === "isca" ? "var(--isca-color)" : "var(--trip-color)";

  return (
    <div>
      <button
        className="flex items-start gap-2 w-full text-left py-1 px-2 rounded hover:bg-[var(--notion-hover)] transition-colors duration-100 group"
        onClick={() => item.description && setOpen(!open)}
      >
        <span className="mt-[5px] flex-shrink-0 w-1.5 h-1.5 rounded-full" style={{ background: dotColor }} />
        <span className="text-[13px] text-[var(--notion-text)] flex-1">{item.label}</span>
        {item.description && (
          <span className="text-[var(--notion-text-secondary)] opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0">
            {open ? <ChevronDown size={12} /> : <ChevronRight size={12} />}
          </span>
        )}
      </button>
      {open && item.description && (
        <div className="ml-5 mb-1 px-2 py-1.5 rounded text-[12px] text-[var(--notion-text-secondary)] italic" style={{ background: "oklch(0.975 0.003 60)" }}>
          {item.description}
        </div>
      )}
    </div>
  );
}

