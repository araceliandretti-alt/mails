// ─── Diagrama de fluxo horizontal ───────────────────────────────────────────

interface FlowDiagramProps {
  activeId: string | null;
  onSelect: (id: string) => void;
}

function FlowDiagram({ activeId, onSelect }: FlowDiagramProps) {
  return (
    <div className="overflow-x-auto pb-2">
      <div className="flex items-center gap-1 min-w-max">
        {FUNIL_DATA.map((node, idx) => (
          <div key={node.id} className="flex items-center gap-1">
            <button
              className={`flow-node ${node.phase} ${activeId === node.id ? "active-node" : ""}`}
              onClick={() => onSelect(node.id)}
            >
              {node.icon}
              <span>{node.label}</span>
            </button>
            {idx < FUNIL_DATA.length - 1 && (
              <span className="flow-arrow">→</span>
            )}
          </div>
        ))}
      </div>
    </div>
  );
}

// ─── Página principal ────────────────────────────────────────────────────────

export default function Home() {
  const [notes, setNotes] = useState<Record<string, string>>(loadNotes);
  const [openIds, setOpenIds] = useState<Set<string>>(new Set());
  const [activeId, setActiveId] = useState<string | null>("overview");
  const [savedIds, setSavedIds] = useState<Set<string>>(new Set());
  const saveTimers = useRef<Record<string, ReturnType<typeof setTimeout>>>({});

  // Debounced save
  const handleNoteChange = useCallback((id: string, val: string) => {
    setNotes((prev) => {
      const next = { ...prev, [id]: val };
      clearTimeout(saveTimers.current[id]);
      saveTimers.current[id] = setTimeout(() => {
        saveNotes(next);
        setSavedIds((s) => {
          const ns = new Set(s);
          ns.add(id);
          return ns;
        });
        setTimeout(() => {
          setSavedIds((s) => {
            const ns = new Set(s);
            ns.delete(id);
            return ns;
          });
        }, 2000);
      }, 600);
      return next;
    });
  }, []);

  const toggleBlock = useCallback((id: string) => {
    setOpenIds((prev) => {
      const next = new Set(prev);
      if (next.has(id)) next.delete(id);
      else next.add(id);
      return next;
    });
  }, []);

  const handleSelect = useCallback((id: string) => {
    setActiveId(id);
    if (id === "overview") return;
    // Abrir bloco e fazer scroll
    setOpenIds((prev) => {
      const next = new Set(prev);
      next.add(id);
      return next;
    });
    setTimeout(() => {
      const el = document.getElementById(`block-${id}`);
      if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
    }, 50);
  }, []);

  // Contagem de notas preenchidas
  const filledNotes = FUNIL_DATA.filter((n) => notes[n.id]?.trim()).length;

  return (
    <div className="flex min-h-screen bg-[var(--background)]">
      {/* Sidebar */}
      <Sidebar activeId={activeId} onSelect={handleSelect} openIds={openIds} />

      {/* Conteúdo principal */}
      <main className="flex-1 min-w-0 overflow-y-auto">
        <div className="max-w-3xl mx-auto px-6 py-8 space-y-8">

          {/* Cabeçalho */}
          <header className="space-y-2">
            <div className="flex items-center gap-2 text-[12px] text-[var(--notion-text-secondary)]" style={{ fontFamily: "'JetBrains Mono', monospace" }}>
              <span>Funil Lipedema</span>
              <span>/</span>
              <span>Canvas Interativo</span>
            </div>
            <h1 className="text-2xl font-bold text-[var(--notion-text)]" style={{ fontFamily: "'DM Sans', sans-serif", letterSpacing: "-0.03em" }}>
              Funil Lipedema
            </h1>
            <p className="text-[13.5px] text-[var(--notion-text-secondary)] max-w-xl">
              Jornada completa de captação e conversão — da aquisição via Meta Ads até o pós-compra. Expanda cada etapa para ver subtópicos e registar anotações.
            </p>
            <div className="flex items-center gap-4 pt-1">
              <div className="flex items-center gap-1.5">
                <span className="w-2 h-2 rounded-full" style={{ background: "var(--isca-color)" }} />
                <span className="text-[12px] text-[var(--notion-text-secondary)]">Isca / Aquisição</span>
              </div>
              <div className="flex items-center gap-1.5">
                <span className="w-2 h-2 rounded-full" style={{ background: "var(--trip-color)" }} />
                <span className="text-[12px] text-[var(--notion-text-secondary)]">Trip / Conversão</span>
              </div>
              <div className="ml-auto flex items-center gap-1.5">
                <FileText size={12} className="text-[var(--notion-text-secondary)]" />
                <span className="text-[12px] text-[var(--notion-text-secondary)]">
                  {filledNotes}/{FUNIL_DATA.length} etapas anotadas
                </span>
              </div>
            </div>
          </header>

          {/* Fluxo visual */}
          <section className="space-y-2">
            <p className="text-[11px] font-semibold text-[var(--notion-text-secondary)] uppercase tracking-wider" style={{ fontFamily: "'JetBrains Mono', monospace" }}>
              Jornada do funil
            </p>
            <div
              className="rounded-lg p-4 border border-[var(--border)]"
              style={{ background: "oklch(0.975 0.003 60)" }}
            >
              <FlowDiagram activeId={activeId} onSelect={handleSelect} />
            </div>
          </section>

          {/* Separador de fase — Isca */}
          <div className="flex items-center gap-3">
            <div className="h-px flex-1" style={{ background: "var(--border)" }} />
            <span
              className="text-[11px] font-semibold uppercase tracking-widest px-2"
