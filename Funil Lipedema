                onActivate={() => setActiveId(node.id)}
              />
            ))}
          </div>

          {/* Rodapé */}
          <footer className="pt-4 pb-8 border-t border-[var(--border)]">
            <div className="flex items-center justify-between">
              <p className="text-[12px] text-[var(--notion-text-secondary)]">
                Funil Lipedema — Canvas Interativo
              </p>
              <div className="flex items-center gap-1.5 text-[12px] text-[var(--notion-text-secondary)]">
                <Zap size={11} />
                <span>Notas salvas localmente no navegador</span>
              </div>
            </div>
          </footer>

        </div>
      </main>
    </div>
  );
}
